{
	"name": "NoTIP Nest Dev",
	"image": "ghcr.io/notipswe/notip-nest-dev:v0.0.1",
	"remoteUser": "node",
	"postCreateCommand": "[ -f package.json ] && npm install; pre-commit install --install-hooks",
	"customizations": {
		"vscode": {
			"extensions": [
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"firsttris.vscode-jest-runner",
				"streetsidesoftware.code-spell-checker",
				"SonarSource.sonarlint-vscode"
			]
		}
	},
	"forwardPorts": [3000],
	"workspaceFolder": "/workspaces/notip-management-api",
	"init": true
}
